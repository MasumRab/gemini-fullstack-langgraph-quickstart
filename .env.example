# Gemini API Configuration
GEMINI_API_KEY=your_api_key_here

# Model Configuration (Optional - Overrides defaults in backend/src/agent/configuration.py)
# Each role uses the best-fit model by default (see backend/src/agent/models.py).
# Uncomment and set these only if you want to override the defaults.
# QUERY_GENERATOR_MODEL=gemini-2.5-flash
# REFLECTION_MODEL=gemini-2.5-flash
# ANSWER_MODEL=gemini-2.5-flash

# Research Configuration
NUMBER_OF_INITIAL_QUERIES=3
MAX_RESEARCH_LOOPS=2
REQUIRE_PLANNING_CONFIRMATION=true

# Optional: Tavily Search API (if using Tavily instead of Google Search)
# TAVILY_API_KEY=your_tavily_api_key_here

# Optional: LangSmith tracing (https://smith.langchain.com/)
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=gemini-fullstack-langgraph
